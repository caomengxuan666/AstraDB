#!/bin/bash
# Post-installation script for AstraDB
set -e

case "$1" in
    configure)
        # Create user if it doesn't exist
        if ! id -u astradb > /dev/null 2>&1; then
            useradd -r -s /bin/false -d /var/lib/astradb -c "AstraDB Server" astradb || true
        fi
        
        # Create directories
        mkdir -p /var/lib/astradb
        mkdir -p /var/log/astradb
        mkdir -p /var/run/astradb
        
        # Set permissions
        chown -R astradb:astradb /var/lib/astradb
        chown -R astradb:astradb /var/log/astradb
        chown -R astradb:astradb /var/run/astradb
        
        echo "AstraDB installed successfully."
        echo "Start with: systemctl start astradb"
        echo "Or run directly: /opt/astradb/bin/astradb /etc/astradb/astradb.toml"
        ;;
        
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
        
    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0