      "name": "macos-release-clang",
      "configurePreset": "macos-release-clang"
    },
    {
      "name": "macos-package-clang",
      "configurePreset": "macos-package-clang"
    },
    {
      "name": "windows-debug-msvc",
      "configurePreset": "windows-debug-msvc"
    },
    {
      "name": "windows-release-msvc",
      "configurePreset": "windows-release-msvc"
    },
    {
      "name": "windows-package-msvc",
      "configurePreset": "windows-package-msvc"
    }
  ],
  "testPresets": [
    {
      "name": "linux-debug-gcc",
      "configurePreset": "linux-debug-gcc",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "linux-debug-clang",
      "configurePreset": "linux-debug-clang",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "macos-debug-clang",
      "configurePreset": "macos-debug-clang",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "windows-debug-msvc",
      "configurePreset": "windows-debug-msvc",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error"
      }
