      "name": "linux-release-clang",
      "configurePreset": "linux-release-clang"
    },
    {
      "name": "linux-release-debuginfo-gcc",
      "configurePreset": "linux-release-debuginfo-gcc"
    },
    {
      "name": "linux-release-debuginfo-clang",
      "configurePreset": "linux-release-debuginfo-clang"
    },
    {
      "name": "linux-package-gcc",
      "configurePreset": "linux-package-gcc"
    },
    {
      "name": "linux-package-clang",
      "configurePreset": "linux-package-clang"
    },
    {
      "name": "macos-debug-clang",
