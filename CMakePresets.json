{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-common",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ASTRADB_BUILD_TESTS": "ON",
        "ASTRADB_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "base-gcc",
      "hidden": true,
      "inherits": "base-common",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "base-clang",
      "hidden": true,
      "inherits": "base-common",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "base-msvc",
      "hidden": true,
      "inherits": "base-common",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "linux-debug-gcc",
      "displayName": "Linux Debug (GCC)",
      "description": "Debug build with GCC on Linux",
      "inherits": "base-gcc",
      "binaryDir": "${sourceDir}/build-linux-debug-gcc",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ASTRADB_ENABLE_SANITIZERS": "ON",
        "ASTRADB_ENABLE_COVERAGE": "ON",
        "ASTRADB_ENABLE_LTO": "OFF"
      }
    },
    {
      "name": "linux-debug-clang",
      "displayName": "Linux Debug (Clang)",
      "description": "Debug build with Clang on Linux",
      "inherits": "base-clang",
      "binaryDir": "${sourceDir}/build-linux-debug-clang",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ASTRADB_ENABLE_SANITIZERS": "ON",
        "ASTRADB_ENABLE_COVERAGE": "ON",
        "ASTRADB_ENABLE_LTO": "OFF"
      }
    },
    {
      "name": "linux-release-gcc",
      "displayName": "Linux Release (GCC)",
      "description": "Release build with GCC on Linux",
      "inherits": "base-gcc",
      "binaryDir": "${sourceDir}/build-linux-release-gcc",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ASTRADB_ENABLE_LTO": "ON",
        "ASTRADB_LINK_MODE": "PARTIAL_STATIC",
        "ASTRADB_BUILD_TESTS": "OFF",
        "ASTRADB_BUILD_BENCHMARKS": "OFF"
      }
    },
    {"name": "linux-release-clang", "displayName": "Linux Release (Clang)", "description": "Release build with Clang on Linux", "inherits": "base-clang", "binaryDir": "${sourceDir}/build-linux-release-clang", "generator": "Ninja", "cacheVariables": {"CMAKE_BUILD_TYPE": "Release", "ASTRADB_ENABLE_LTO": "ON", "ASTRADB_LINK_MODE": "PARTIAL_STATIC", "ASTRADB_BUILD_TESTS": "OFF", "ASTRADB_BUILD_BENCHMARKS": "OFF"}},
    {"name": "linux-release-debuginfo-gcc", "displayName": "Linux Release with Debug Info (GCC)", "description": "Release build with debug info (no strip) on Linux with GCC", "inherits": "base-gcc", "binaryDir": "${sourceDir}/build-linux-release-debuginfo-gcc", "generator": "Ninja", "cacheVariables": {"CMAKE_BUILD_TYPE": "RelWithDebInfo", "ASTRADB_ENABLE_LTO": "OFF", "ASTRADB_LINK_MODE": "PARTIAL_STATIC", "ASTRADB_STRIP_SYMBOLS": "OFF"}},
    {"name": "linux-release-debuginfo-clang", "displayName": "Linux Release with Debug Info (Clang)", "description": "Release build with debug info (no strip) on Linux with Clang", "inherits": "base-clang", "binaryDir": "${sourceDir}/build-linux-release-debuginfo-clang", "generator": "Ninja", "cacheVariables": {"CMAKE_BUILD_TYPE": "RelWithDebInfo", "ASTRADB_ENABLE_LTO": "OFF", "ASTRADB_LINK_MODE": "PARTIAL_STATIC", "ASTRADB_STRIP_SYMBOLS": "OFF"}},
    {
      "name": "macos-debug-clang",
      "displayName": "macOS Debug (Clang)",
      "description": "Debug build with Clang on macOS",
      "inherits": "base-clang",
      "binaryDir": "${sourceDir}/build-macos-debug-clang",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ASTRADB_ENABLE_SANITIZERS": "ON",
        "ASTRADB_ENABLE_COVERAGE": "ON",
        "ASTRADB_ENABLE_LTO": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {"name": "macos-release-clang", "displayName": "macOS Release (Clang)", "description": "Release build with Clang on macOS", "inherits": "base-clang", "binaryDir": "${sourceDir}/build-macos-release-clang", "generator": "Ninja", "cacheVariables": {"CMAKE_BUILD_TYPE": "Release", "ASTRADB_ENABLE_LTO": "ON", "ASTRADB_BUILD_TESTS": "OFF", "ASTRADB_BUILD_BENCHMARKS": "OFF"}, "condition": {"type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin"}},
    {
      "name": "windows-debug-msvc",
      "displayName": "Windows Debug (MSVC)",
      "description": "Debug build with MSVC on Windows",
      "inherits": "base-msvc",
      "binaryDir": "${sourceDir}/build-windows-debug-msvc",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ASTRADB_ENABLE_SANITIZERS": "OFF",
        "ASTRADB_ENABLE_LTO": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {"name": "windows-release-msvc", "displayName": "Windows Release (MSVC)", "description": "Release build with MSVC on Windows", "inherits": "base-msvc", "binaryDir": "${sourceDir}/build-windows-release-msvc", "generator": "Ninja", "cacheVariables": {"CMAKE_BUILD_TYPE": "Release", "ASTRADB_ENABLE_LTO": "ON", "ASTRADB_BUILD_TESTS": "OFF", "ASTRADB_BUILD_BENCHMARKS": "OFF"}, "condition": {"type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows"}},
    {
      "name": "package-common",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ASTRADB_ENABLE_LTO": "ON",
        "ASTRADB_BUILD_TESTS": "OFF",
        "ASTRADB_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "linux-package-gcc",
      "displayName": "Linux Package (GCC)",
      "description": "Release build for packaging on Linux with GCC",
      "inherits": [
        "package-common",
        "base-gcc"
      ],
      "binaryDir": "${sourceDir}/build-linux-package-gcc",
      "generator": "Ninja"
    },
    {
      "name": "linux-package-clang",
      "displayName": "Linux Package (Clang)",
      "description": "Release build for packaging on Linux with Clang",
      "inherits": [
        "package-common",
        "base-clang"
      ],
      "binaryDir": "${sourceDir}/build-linux-package-clang",
      "generator": "Ninja"
    },
    {
      "name": "macos-package-clang",
      "displayName": "macOS Package (Clang)",
      "description": "Release build for packaging on macOS with Clang",
      "inherits": [
        "package-common",
        "base-clang"
      ],
      "binaryDir": "${sourceDir}/build-macos-package-clang",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "windows-package-msvc",
      "displayName": "Windows Package (MSVC)",
      "description": "Release build for packaging on Windows with MSVC",
      "inherits": [
        "package-common",
        "base-msvc"
      ],
      "binaryDir": "${sourceDir}/build-windows-package-msvc",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug-gcc",
      "configurePreset": "linux-debug-gcc"
    },
    {
      "name": "linux-debug-clang",
      "configurePreset": "linux-debug-clang"
    },
    {
      "name": "linux-release-gcc",
